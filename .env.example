# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# OpenAI API (chat, code generation, prompt refinement, and DALL-E 3)
OPENAI_API_KEY=sk-your-key-here

# Gemini API (low-cost chat routing)
GEMINI_API_KEY=your-gemini-key-here
# Optional routing overrides
GEMINI_LOW_TIER_MODEL=gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash

# Resend Email API
RESEND_API_KEY=re_your-key-here

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_your-key-here

# Node Environment
NODE_ENV=production

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Roblox Open Cloud Assets API (optional; enables generated preview upload)
# Keep the API key server-side only. Configure either a creator user or group ID.
ROBLOX_OPEN_CLOUD_API_KEY=your-open-cloud-api-key-here
ROBLOX_ASSET_CREATOR_USER_ID=your-roblox-user-id
# ROBLOX_ASSET_CREATOR_GROUP_ID=your-roblox-group-id
